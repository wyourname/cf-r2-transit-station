{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "cf-r2-transit-station-github",
	"main": "src/index.ts",
	"compatibility_date": "2025-12-13",
	"compatibility_flags": [
		"global_fetch_strictly_public"
	],
	"triggers": {
		"crons": [
			"0 * * * *"
		]
	},
	// "vars": {
	// 	// 建议在 Dashboard 中覆盖此变量以提高安全性
	// 	"ADMIN_PASSWORD": "changeme123"
	// },
	"observability": {
		"enabled": true
	}
}